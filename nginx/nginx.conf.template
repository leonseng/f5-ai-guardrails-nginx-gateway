load_module modules/ngx_http_js_module.so;

# Log to stderr at warn level so js_periodic startup messages are visible.
# (Without this, nginx uses its compiled-in default: logs/error.log at error level.)
error_log /var/log/nginx/error.log warn;

# All env vars that NJS reads via process.env must be declared here,
# at the top-level (main) context, outside http {}.
# nginx strips env vars by default; these directives preserve them.
env F5_AI_GUARDRAILS_API_URL;
env F5_AI_GUARDRAILS_API_TOKEN;
env F5_AI_GUARDRAILS_PROJECT_ID;
env F5_AI_GUARDRAILS_SCAN_PROMPT;
env F5_AI_GUARDRAILS_SCAN_RESPONSE;
env F5_AI_GUARDRAILS_REDACT_PROMPT;
env F5_AI_GUARDRAILS_REDACT_RESPONSE;
env F5_AI_GUARDRAILS_FAIL_OPEN;
env DEBUG;

events {}

http {
    js_path "/etc/nginx/njs/";
    js_import main from guardrails.js;

    # Trust the system CA bundle for ngx.fetch() HTTPS calls (e.g. F5 AI Guardrails API).
    js_fetch_trusted_certificate /etc/ssl/certs/ca-certificates.crt;

    # Required when proxy_pass uses a variable (set $var ...).
    # 127.0.0.11 is Docker's embedded DNS resolver.
    resolver 127.0.0.11 valid=10s;

    # Buffer full request body before NJS reads r.requestText.
    client_body_buffer_size      10m;
    client_max_body_size         10m;
    # Buffer NJS subrequest responses (default 4096 bytes is too small for LLM responses).
    subrequest_output_buffer_size 10m;

    server {
        listen 11434;

        # Pass all non-completions traffic straight through (e.g. /models).
        location / {
            proxy_pass           ${OPENAI_API_URL}/;
            proxy_set_header     Host $proxy_host;
            proxy_ssl_server_name on;
        }

        # Guardrail-aware completions — NJS owns this location entirely.
        location = /chat/completions {
            js_content main.handleChatCompletions;
        }

        # Internal-only upstream LLM backend; NJS subrequests land here.
        location /app/ {
            internal;
            proxy_pass           ${OPENAI_API_URL}/;
            proxy_set_header     Host $proxy_host;
            proxy_set_header     Content-Type "application/json";
            proxy_pass_request_body on;
            proxy_ssl_server_name on;
        }
    }
}
