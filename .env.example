# Upstream LLM
OPENAI_API_URL=https://your.ollama.host:11434

# F5 AI Guardrails (CalypsoAI)
F5_AI_GUARDRAILS_API_URL=https://www.us1.calypsoai.app/backend/v1
F5_AI_GUARDRAILS_API_TOKEN=your_guardrails_api_token
F5_AI_GUARDRAILS_PROJECT_ID=your_project_id

# Set to false to disable individual scan directions
F5_AI_GUARDRAILS_SCAN_PROMPT=true
F5_AI_GUARDRAILS_SCAN_RESPONSE=true

# Set to true to replace flagged content with CalypsoAI's redacted version instead of passing through unchanged
F5_AI_GUARDRAILS_REDACT_PROMPT=false
F5_AI_GUARDRAILS_REDACT_RESPONSE=false

# Set to true to pass requests through if the guardrails scan API returns any error
# (network failure, non-2xx response, or unparseable response). Default is false (fail-closed).
F5_AI_GUARDRAILS_FAIL_OPEN=false

# Enable verbose NJS logging
DEBUG=false
