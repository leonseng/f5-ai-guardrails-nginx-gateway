# Upstream LLM
OPENAI_API_URL=https://your.ollama.host:11434
OPENAI_API_KEY=your-openai-or-ollama-api-key

# F5 AI Guardrails (CalypsoAI)
F5_AI_GUARDRAILS_API_URL=https://www.us1.calypsoai.app/backend/v1
F5_AI_GUARDRAILS_API_TOKEN=your_guardrails_api_token
F5_AI_GUARDRAILS_PROJECT_ID=your_project_id

# Set to false to disable individual scan directions
F5_AI_GUARDRAILS_SCAN_PROMPT=true
F5_AI_GUARDRAILS_SCAN_RESPONSE=true

# Enable verbose NJS logging
DEBUG=false
